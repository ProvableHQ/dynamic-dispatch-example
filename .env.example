# ── Environment Files ──────────────────────────────────────────────
# Create named env files per network to avoid overwriting secrets:
#
#   .env.devnet   — local devnode (committed, safe defaults)
#   .env.canary   — canary network (gitignored)
#   .env.mainnet  — mainnet (gitignored)
#
# Select which file to use:
#   DOTENV=canary npx tsx scripts/deploy.ts
#   DOTENV=canary npm test
#
# Or pass --env:
#   npx tsx scripts/deploy.ts --env canary
#
# Falls back to .env if no DOTENV or --env is specified.

# ── Network Configuration ──────────────────────────────────────────
NETWORK=testnet
ENDPOINT=http://localhost:3030

# ── Leo Binary ────────────────────────────────────────────────────
# Path to the leo binary. The CLI backend (live networks) uses this
# for `leo execute` and `leo deploy`. Defaults to "leo" (PATH lookup).
# LEO_BIN=/path/to/leo

# ── Private Keys ──────────────────────────────────────────────────
# PRIVATE_KEY_0 is the deployer / primary account.
# PRIVATE_KEY_1 is the recipient in transfer tests/demo.
PRIVATE_KEY_0=APrivateKey1zkp8CZNn3yeCseEtxuVPbDCwSyhGW6yZKUYKfgXmcpoGPWH
PRIVATE_KEY_1=APrivateKey1zkp2RWGDcde3efb89rjhME1VYA8QMxcxep5DShNBR6n8Yjh
